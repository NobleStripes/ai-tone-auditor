# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required when AI_PROVIDER or AI_FALLBACK_PROVIDER uses openai.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: Optional model override for OpenAI provider.
OPENAI_MODEL="gpt-4o-mini"

# ANTHROPIC_API_KEY: Required when AI_PROVIDER or AI_FALLBACK_PROVIDER uses anthropic.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# ANTHROPIC_MODEL: Optional model override for Anthropic provider.
ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# AI_PROVIDER: Primary AI provider used for analysis.
# Supported values: gemini, openai, anthropic, local
AI_PROVIDER="gemini"

# AI_FALLBACK_PROVIDER: Backup provider used when primary fails.
# Supported values: gemini, openai, anthropic, local
AI_FALLBACK_PROVIDER="anthropic"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
